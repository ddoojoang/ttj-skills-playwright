    "type": "git",
    "url": "git+https://github.com/ddoojoang/ttj-skills-playwright.git"
  },
  "bugs": {
    "url": "https://github.com/ddoojoang/ttj-skills-playwright/issues"
  },
  "homepage": "https://github.com/ddoojoang/ttj-skills-playwright#readme",
  "engines": {
    "node": ">=18.0.0"
  }
