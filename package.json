{
  "name": "ttj-skills-browser",
  "version": "1.2.13",
  "description": "ttj-skills-browser - Dedicated CDP browser with one-shot commands (eval/goto/screenshot) and page reference visualization",
  "type": "module",
  "bin": {
    "ttj-skills-browser": "dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
